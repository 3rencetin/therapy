# Genel (tarayıcı + sunucu)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# İsteğe bağlı; boş bırakılırsa NEXT_PUBLIC_SUPABASE_URL + /rest/v1 kullanılır
NEXT_PUBLIC_SUPABASE_REST_URL=https://YOUR_PROJECT_REF.supabase.co/rest/v1
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sunucu tarafı — asla NEXT_PUBLIC yapmayın, istemciye göndermeyin
SUPABASE_SERVICE_ROLE_KEY=

# Supabase yeni anahtar formatı (panelde görüyorsanız; istemci yine anon JWT ile çalışır)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Görüntülü görüşme (LiveKit Cloud) — https://cloud.livekit.io
# Örnek: wss://YOUR_PROJECT.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Bilgi köşesi — «İngilizceye çevir» (varsayılan: ücretsiz MyMemory, kart yok)
# İsteğe bağlı: günlük kotayı artırmak için kayıtlı e-posta (https://mymemory.translated.net)
# MYMEMORY_CONTACT_EMAIL=you@example.com
# İsteğe bağlı DeepL (kart isteyebilir)
# DEEPL_API_KEY=
# İsteğe bağlı LibreTranslate sunucusu
# LIBRETRANSLATE_URL=
# LIBRETRANSLATE_API_KEY=
